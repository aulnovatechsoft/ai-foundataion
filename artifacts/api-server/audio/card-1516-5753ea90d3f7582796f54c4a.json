{"audioUrl":"/api/audio/card-1516-5753ea90d3f7582796f54c4a.mp3","durationSec":27.94,"sentences":[{"id":0,"text":"Keeping the plan alive","startTime":0,"endTime":1.82},{"id":1,"text":"A payoff plan isn't static.","startTime":1.82,"endTime":4.14},{"id":2,"text":"Life changes — a bonus arrives, a rate changes, an emergency hits.","startTime":4.14,"endTime":10.1},{"id":3,"text":"Instead of the plan silently dying, bring the change to AI:","startTime":10.1,"endTime":14.2},{"id":4,"text":"\"I got an unexpected [amount].","startTime":14.2,"endTime":15.66},{"id":5,"text":"Where does it do the most good in my plan?\"","startTime":15.66,"endTime":18.28},{"id":6,"text":"\"I had to skip this month's extra payment.","startTime":18.28,"endTime":21.2},{"id":7,"text":"Rebuild my timeline.\"","startTime":21.2,"endTime":22.86},{"id":8,"text":"\"My card's promo rate ends next month.","startTime":22.86,"endTime":25.76},{"id":9,"text":"Does my payoff order change?\"","startTime":25.76,"endTime":27.94}]}